# ──────────────────────────────────────────────
# District Pour Haus — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────

# ── Database (Drizzle / Postgres) ─────────────
# Full Postgres connection string for Drizzle ORM and migrations.
DATABASE_URL=postgresql://postgres:password@localhost:5432/dph

# ── Supabase ──────────────────────────────────
# Project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — NEVER expose to the browser. Used in server-only admin helpers.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Site ──────────────────────────────────────
# Canonical public URL of this deployment (no trailing slash).
# Used for metadata, sitemaps, redirects, and OG images.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Integrations encryption ───────────────────
# 32-byte (256-bit) hex key used to AES-encrypt third-party credentials stored
# in the `integrations` DB table. Generate with: openssl rand -hex 32
INTEGRATIONS_ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ── Resend (transactional email) ──────────────
# API key from resend.com — server-only.
RESEND_API_KEY=re_your_resend_api_key

# "From" address for outbound email. Domain must be verified in the Resend dashboard.
RESEND_FROM_EMAIL=District Pour Haus <hello@districtpourhaus.com>

# Reply-to address for staff-notification emails. Defaults to RESEND_FROM_EMAIL if unset.
RESEND_REPLY_TO=info@districtpourhaus.com

# ── Cloudflare Turnstile (CAPTCHA) ────────────
# Site key — safe to expose to the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Secret key — server-only, used to verify Turnstile challenge tokens.
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ── Cron jobs ─────────────────────────────────
# Bearer token that Vercel Cron (or any scheduler) must send in the
# Authorization header when invoking /api/cron/* routes.
CRON_SECRET=your-cron-secret

# ── Mapbox (static map images) ────────────────
# PUBLIC Mapbox token (begins with pk.*).
# This token is embedded in image src URLs and is therefore visible to end-users.
# Restrict it to your site domain in the Mapbox dashboard:
#   Account → Access tokens → [token] → Allowed URLs → https://districtpourhaus.com
# Used by MapBlock (components/marketing/MapBlock.tsx) to render the Static Images API tile.
MAPBOX_TOKEN=pk.your_mapbox_public_token

# ── Seed scripts (dev only) ───────────────────
# These are only used by scripts/seed-users.ts and are never read at runtime.
SEED_ADMIN_EMAIL=admin@districtpourhaus.test
SEED_ADMIN_PASSWORD=dph-admin-dev-pass
SEED_STAFF_EMAIL=staff@districtpourhaus.test
SEED_STAFF_PASSWORD=dph-staff-dev-pass
# Set to "1" to allow the seed script to run against a production DATABASE_URL.
SEED_ALLOW_PROD=0
