{
  "permissions": {
    "deny": [
      "Bash(supabase db push)",
      "Bash(supabase db push:*)",
      "Bash(supabase link:*)",
      "Bash(supabase migration up --linked:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-remote-db-push.py\""
          }
        ]
      }
    ]
  }
}
